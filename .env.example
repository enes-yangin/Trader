# TraderAI Environment Configuration
# Copy this file to '.env' in the same folder and fill in your keys.
#   PowerShell:  Copy-Item .env.example .env
# A real OS environment variable always wins over the .env value.

# HuggingFace token — news/FinBERT sentiment. Raises the HF download rate
# limit (429) so the one-time ~400MB model download succeeds.
# Get a free token (type: Read) at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Exchange (ccxt id). If Binance is geo-blocked, use a reachable one.
# Options: kraken, binance, kucoin, okx, bybit, coinbase, gateio, mexc
AI_TRADER_EXCHANGE=kraken

# Sentiment backend: finbert | distilbert | vader
# If your network blocks HuggingFace entirely, set 'vader' (local, no download).
AI_TRADER_SENTIMENT_BACKEND=finbert

# FRED (Federal Reserve Economic Data) API Key for DXY & Liquidity features
# Get a free key at: https://fred.stlouisfed.org/api/keys.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI Key for historical news sentiment analysis
# Get a free key at: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Reddit & X (Twitter) API Keys (Optional - for advanced social metrics customization)
# REDDIT_API_KEY=your_reddit_key
# X_API_KEY=your_x_key

# Global configurations overrides (Optional)
# AI_TRADER_USE_LEVERAGE=False
# AI_TRADER_SENTIMENT_BACKEND=finbert
